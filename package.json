{
  "name": "synclounge",
  "version": "0.0.0-semantically-released",
  "description": "Synced playback of Plex content",
  "author": "samcm",
  "bin": "./server.js",
  "files": [
    "dist",
    "config",
    "server.js"
  ],
  "scripts": {
